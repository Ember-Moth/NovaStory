{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "oxc"],
  "ignorePatterns": ["dist/", "out/"],
  "env": {
    "browser": true,
    "node": true,
    "es2026": true
  },
  "globals": {
    "Bun": "readonly"
  },
  "settings": {
    "react": {
      "version": "19.2.7"
    }
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "react/react-in-jsx-scope": "off",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "warn"
  }
}
