{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "prepare": "husky",
    "lint": "oxlint --deny-warnings .",
    "format": "prettier --write src/",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix --deny-warnings",
      "prettier --write"
    ],
    "*.{json,md,css,html,yaml,yml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/azure": "^4.0.0",
    "@ai-sdk/cerebras": "^3.0.0",
    "@ai-sdk/gateway": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@ai-sdk/react": "^4.0.0",
    "@ai-sdk/xai": "^4.0.0",
    "auto-transition": "github:Ember-Moth/auto-transition",
    "@codehz/rpc": "^0.1.8",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@floating-ui/react": "^0.27.19",
    "@iconify/json": "^2.2.483",
    "@iconify/tailwind4": "^1.2.3",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@uiw/react-codemirror": "^4.25.10",
    "ai": "^7.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "bunshi": "^2.2.0",
    "codemirror": "^6.0.2",
    "lexical": "^0.45.0",
    "motion": "^12.40.0",
    "nano-git": "^0.4.1",
    "nanoid": "^5.1.11",
    "partial-json": "^0.1.7",
    "react": "^19",
    "react-dom": "^19",
    "rehype-harden": "^1.1.8",
    "simplebar-react": "^3.3.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "wouter": "^3.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
