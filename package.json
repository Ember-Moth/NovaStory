{
  "name": "nova-story",
  "version": "0.1.0",
  "private": true,
  "description": "A creative writing workstation that models novel creation as a branchable workspace with timeline-aware world state.",
  "author": "Ember Moth",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "rsbuild dev --port 3001",
    "dev:main": "tsc -p tsconfig.main.json --watch --outDir dist/main",
    "dev:electron": "wait-on http://localhost:3001 && electron dist/main/index.js",
    "start": "NODE_ENV=production electron dist/main/index.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "rsbuild build",
    "build:main": "tsc -p tsconfig.main.json --outDir dist/main",
    "package": "electron-builder",
    "prepare": "husky",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write src/",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,html,yaml,yml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/azure": "^4.0.0",
    "@ai-sdk/cerebras": "^3.0.0",
    "@ai-sdk/gateway": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@ai-sdk/react": "^4.0.0",
    "@ai-sdk/xai": "^4.0.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@floating-ui/react": "^0.27.19",
    "@iconify/json": "^2.2.483",
    "@iconify/tailwind4": "^1.2.3",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@lezer/highlight": "^1.2.3",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@uiw/react-codemirror": "^4.25.10",
    "ai": "^7.0.0",
    "auto-transition": "github:Ember-Moth/auto-transition",
    "better-sqlite3": "^11.0.0",
    "bunshi": "^2.2.0",
    "codemirror": "^6.0.2",
    "lexical": "^0.45.0",
    "motion": "^12.40.0",
    "nano-git": "github:Ember-Moth/nano-git",
    "nanoid": "^5.1.11",
    "partial-json": "^0.1.7",
    "react": "^19",
    "react-dom": "^19",
    "rehype-harden": "^1.1.8",
    "simplebar-react": "^3.3.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "wouter": "^3.10.0",
    "yaml": "^2.7.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@rsbuild/core": "^1.4.0",
    "@rsbuild/plugin-react": "^1.4.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^36.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "electron-builder": "^25.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  }
}
